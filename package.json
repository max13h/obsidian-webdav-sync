{
	"name": "obsidian-webdav-sync",
	"version": "0.0.1",
	"description": "Straight to the point plugin to sync your vault with a WebDAV server.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@types/node": "^25.5.2",
		"esbuild": "0.28.0",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "17.4.0",
		"jiti": "2.6.1",
		"tslib": "2.8.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "8.58.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
